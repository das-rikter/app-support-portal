# Generate with: openssl rand -base64 32
AUTH_SECRET=

# From Azure Portal > App Registrations > your app
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# Application URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Required when running behind a reverse proxy (e.g. Azure Container Apps)
# AUTH_TRUST_HOST=true

# Backend API base URL (optional - configure when API is available)
NEXT_PUBLIC_API_BASE_URL=
