# Generate with: openssl rand -base64 32
AUTH_SECRET=

# From Azure Portal > App Registrations > your app
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# Application URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Required when running behind a reverse proxy (e.g. Azure Container Apps)
# AUTH_TRUST_HOST=true

# Comma-separated list of emails that are granted Admin role on first sign-in
# AUTH_ADMIN_EMAILS=admin@example.com,another@example.com
AUTH_ADMIN_EMAILS=

# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/app_support_portal
DATABASE_URL=

# Backend API base URL (optional - configure when external API is available)
NEXT_PUBLIC_API_BASE_URL=

# Jira integration (Atlassian Cloud)
# Base URL of your Jira instance, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=
# Atlassian account email used to generate the API token
JIRA_EMAIL=
# Atlassian API token - generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Better Stack Uptime API key - generate at https://betterstack.com/team/api-keys
BETTERSTACK_API_KEY=

# Logging - pino log level: trace | debug | info | warn | error (default: debug in dev, info in prod)
# LOG_LEVEL=debug
# LOG_TO_FILE=true
